# Copy this file to `.env` (same directory as docker-compose.yaml) and set real values.
# `.env` is gitignored and must never be committed.

# SQL Server SA password. Must meet SQL Server complexity requirements
# (>= 8 chars, with upper, lower, digit and symbol).
MSSQL_SA_PASSWORD=

# Symmetric signing key for JWT tokens. Use a long, random value.
JWT_KEY=
